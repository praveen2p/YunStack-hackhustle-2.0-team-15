DATABASE_URL=sqlite:///./medmemory.db
SECRET_KEY=change-this-to-a-long-random-secret-key
# Optional 32-byte base64url key for AES-256-GCM record encryption.
# If unset, the app derives a development key from SECRET_KEY.
AES_256_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
ALGORITHM=HS256
GEMINI_API_KEY=
FHIR_DATASET_DIR=/Users/apple/Downloads/csv

# Optional MongoDB document storage for uploaded clinical files.
# Use mongodb://localhost:27017 for local MongoDB or a mongodb+srv:// Atlas URI.
MONGODB_URI=
MONGODB_DATABASE=medmemory
MONGODB_GRIDFS_BUCKET=medical_documents
MONGODB_REQUIRED=false
